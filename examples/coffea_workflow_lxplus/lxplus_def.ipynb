      "  3. ssh <username>@lxplus.cern.ch\n",
      "  4. condor_submit -interactive        # get a batch node, wait for shell\n",
      "  5. cp ~/worker.def .  &&  apptainer build --fakeroot worker.sif worker.def\n",
